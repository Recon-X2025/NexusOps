{
  "name": "@nexusops/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/types.d.ts",
  "scripts": {
    "predev": "pnpm --filter @nexusops/db exec tsup --no-dts",
    "dev": "tsx watch src/index.ts",
    "start:dev": "pnpm --filter @nexusops/db db:migrate && tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.37.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@nexusops/db": "workspace:*",
    "@nexusops/metrics": "workspace:*",
    "@nexusops/types": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "@trpc/server": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.6.0",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.0",
    "isomorphic-dompurify": "^3.7.1",
    "jsonwebtoken": "^9.0.0",
    "meilisearch": "^0.44.0",
    "mongodb": "^6.12.0",
    "nanoid": "^5.0.0",
    "nodemailer": "^8.0.3",
    "openid-client": "^6.8.2",
    "pdfkit": "^0.18.0",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nexusops/config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.8",
    "supertest": "^7.2.2",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
