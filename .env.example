# =============================================================================
# CoheronConnect Environment Variables
# Copy this file to .env and fill in values for local development
# =============================================================================

# --- Database (OLTP) ---
# Three supported modes (DATABASE_PROVIDER or DATABASE_OLTP_PROVIDER):
#
#   postgres — PostgreSQL only (Drizzle). MONGODB_URI is ignored (warning if set).
#   hybrid   — DATABASE_URL + MONGODB_URI both required; API connects both at startup.
#   mongo    — MONGODB_URI required; DATABASE_URL still required (Drizzle OLTP until migrated).
#
# Aliases: postgresql→postgres, dual|both|postgres+mongo→hybrid, mongodb→mongo
#
DATABASE_URL="postgresql://coheronconnect:coheronconnect@localhost:5434/coheronconnect"
DATABASE_DIRECT_URL="postgresql://coheronconnect:coheronconnect@localhost:5434/coheronconnect"
# After pulling schema changes, apply SQL migrations: pnpm db:migrate
# DATABASE_PROVIDER=postgres
#
# For hybrid or mongo:
# MONGODB_URI="mongodb://localhost:27017"
# MONGODB_DB_NAME="coheronconnect"
# Start local Mongo: docker compose -f docker-compose.dev.yml --profile mongo up -d

# --- Database Connection Pool ---
# Max connections in the pool.  Production default: 20.  Dev default: 30.
# Keep well below Postgres max_connections (typically 100).
# DB_POOL_MAX=20
#
# Seconds an idle connection is held before closing (default: 30).
# DB_POOL_IDLE_TIMEOUT=30
#
# Seconds to wait for an available connection before failing (default: 15).
# Increase for stress tests that saturate the pool.
# DB_POOL_CONNECT_TIMEOUT=15
#
# Seconds before a connection is forcibly recycled (default: 1800 = 30 min).
# DB_POOL_MAX_LIFETIME=1800

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Meilisearch ---
MEILISEARCH_URL="http://localhost:7700"
MEILISEARCH_KEY="masterKey"

# --- Temporal ---
TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="coheronconnect"
# When true, workflow publish fails (PRECONDITION_FAILED) if Temporal is unavailable instead of degraded mode.
NEXUSOPS_WORKFLOW_ENGINE_REQUIRED="false"

# --- Auth (generate with: openssl rand -hex 32) ---
AUTH_SECRET="change-me-generate-with-openssl-rand-hex-32"
AUTH_URL="http://localhost:3000"

# --- Encryption (AES-256, 32 bytes, generate with: openssl rand -hex 32) ---
ENCRYPTION_KEY="change-me-generate-with-openssl-rand-hex-32"

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI / Anthropic ---
ANTHROPIC_API_KEY=""

# --- File Storage (S3 / MinIO) ---
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="coheronconnect"
S3_REGION="us-east-1"

# --- SMTP (optional, for email notifications) ---
SMTP_HOST="localhost"
SMTP_PORT="1025"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="CoheronConnect <noreply@coheronconnect.coheron.com>"

# --- App ---
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"
#
# Full QA / Playwright / chaos (defaults match local dev; set for remote targets)
# NEXUS_QA_BASE_URL=http://localhost:3000
# NEXUS_QA_API_URL=http://localhost:3001
# CHAOS_BASE_URL=http://localhost:3000
# Set to "true" only for internal demos — shows the mock RBAC user switcher in the header.
# NEXT_PUBLIC_ENABLE_DEMO_ROLE_SWITCHER="true"
#
# People & Workplace KPI strip on platform home (/app/dashboard) — requires hr:read
# NEXT_PUBLIC_HOME_HR_STRIP="true"

# --- Rate Limiting ---
# Per-token limit per window.  Production default: 1 000.  Dev default: 10 000.
# Raise to 200 000 in .env when running 10 K-session stress tests.
# RATE_LIMIT_MAX=1000
#
# Per-IP limit per window for unauthenticated requests.
# Production default: 100.  Dev default: 1 000.
# RATE_LIMIT_ANON_MAX=100
#
# Sliding-window length — any ms-compatible string (default: "1 minute").
# RATE_LIMIT_WINDOW="1 minute"

# --- License (Coheron license key for self-hosted) ---
LICENSE_KEY=""
