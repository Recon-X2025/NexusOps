# ── CoheronConnect Production Environment ──────────────────────────────────────────
# Copy this file to your server as .env.production and fill in every value.
# Generate random secrets with:  bash scripts/gen-secrets.sh <server-ip>
#
# NEVER commit .env.production — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Public IP or domain of your Vultr server (no protocol, no trailing slash)
SERVER_IP=YOUR_SERVER_IP

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_PROVIDER: postgres | hybrid | mongo (see root .env.example).
# hybrid/mongo require MONGODB_URI. All modes still need DATABASE_URL for Drizzle today.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below
DATABASE_URL=postgresql://coheronconnect:CHANGE_ME@postgres:5432/coheronconnect
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_USER=coheronconnect
POSTGRES_DB=coheronconnect

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Use: openssl rand -base64 48
JWT_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME
SESSION_TTL_HOURS=8

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200000
RATE_LIMIT_ANON_MAX=200000

# ── Database connection pool ──────────────────────────────────────────────────
DB_POOL_MAX=30
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
DB_POOL_MAX_LIFETIME=1800

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
# Use: openssl rand -base64 48
MEILISEARCH_KEY=CHANGE_ME

# ── MinIO (S3-compatible local object storage) ────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=coheronconnect
# Required by MinIO / S3-compatible providers. Auto-enabled when S3_ENDPOINT is set;
# set to false only for real AWS S3 with virtual-host-style addressing.
S3_FORCE_PATH_STYLE=true

# ── APP_SECRET (REQUIRED) ─────────────────────────────────────────────────────
# Encryption key for stored integration credentials. WITHOUT THIS, saving ANY
# integration (Slack, Razorpay, GST, etc.) fails with "APP_SECRET is not configured".
# Generate: openssl rand -hex 32
APP_SECRET=CHANGE_ME

# ── Session cache behaviour ───────────────────────────────────────────────────
# Set to true to flush stale sessions from Redis on every API restart
FLUSH_REDIS_SESSION_ON_START=true

# ── Email / SMTP (REQUIRED for user invites, password resets, notifications) ──
# WITHOUT SMTP_HOST, all outbound email silently no-ops (logged only, never sent).
# Use a real provider in production (Amazon SES, Postmark, SendGrid, …).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address — note the variable name is SMTP_FROM (not EMAIL_FROM).
SMTP_FROM=CoheronConnect <noreply@yourdomain.com>

# ── Optional: AI features (leave blank to disable) ───────────────────────────
# OPENAI_API_KEY=

# ── GHCR (only if you deploy with DEPLOY_MODE=pull and packages are private) ─
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_xxx_read_packages
# Optional defaults for scripts/push-to-vultr.sh (override per-invocation if needed):
# NEXUSOPS_IMAGE_REPO=ghcr.io/recon-x2025/coheronconnect
# NEXUSOPS_IMAGE_TAG=latest
