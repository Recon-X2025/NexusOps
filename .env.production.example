# ── NexusOps Production Environment ──────────────────────────────────────────
# Copy this file to your server as .env.production and fill in every value.
# Generate random secrets with:  bash scripts/gen-secrets.sh <server-ip>
#
# NEVER commit .env.production — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# Public IP or domain of your Vultr server (no protocol, no trailing slash)
SERVER_IP=YOUR_SERVER_IP

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_PROVIDER: postgres | hybrid | mongo (see root .env.example).
# hybrid/mongo require MONGODB_URI. All modes still need DATABASE_URL for Drizzle today.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below
DATABASE_URL=postgresql://nexusops:CHANGE_ME@postgres:5432/nexusops
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_USER=nexusops
POSTGRES_DB=nexusops

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Use: openssl rand -base64 48
JWT_SECRET=CHANGE_ME
SESSION_SECRET=CHANGE_ME
SESSION_TTL_HOURS=8

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200000
RATE_LIMIT_ANON_MAX=200000

# ── Database connection pool ──────────────────────────────────────────────────
DB_POOL_MAX=30
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
DB_POOL_MAX_LIFETIME=1800

# ── Meilisearch ───────────────────────────────────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
# Use: openssl rand -base64 48
MEILISEARCH_KEY=CHANGE_ME

# ── MinIO (S3-compatible local object storage) ────────────────────────────────
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=CHANGE_ME
S3_SECRET_KEY=CHANGE_ME
S3_BUCKET=nexusops

# ── Session cache behaviour ───────────────────────────────────────────────────
# Set to true to flush stale sessions from Redis on every API restart
FLUSH_REDIS_SESSION_ON_START=true

# ── Optional: email (leave blank to disable) ──────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@yourdomain.com

# ── Optional: AI features (leave blank to disable) ───────────────────────────
# OPENAI_API_KEY=

# ── GHCR (only if you deploy with DEPLOY_MODE=pull and packages are private) ─
# GHCR_USERNAME=your-github-username
# GHCR_TOKEN=ghp_xxx_read_packages
# Optional defaults for scripts/push-to-vultr.sh (override per-invocation if needed):
# NEXUSOPS_IMAGE_REPO=ghcr.io/recon-x2025/nexusops
# NEXUSOPS_IMAGE_TAG=latest
